# Supabase — copy to .env.local and fill in once a project exists.
# Until then the app runs against the seed fixtures (see src/lib/data).
#
# Uses Supabase's current API keys (sb_publishable_… / sb_secret_…).
# The legacy anon / service_role JWT keys are intentionally NOT used.
NEXT_PUBLIC_SUPABASE_URL=
# Browser-safe, respects RLS. From Settings → API Keys → "Publishable key".
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only, bypasses RLS. From Settings → API Keys → "Secret key". Keep private.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Direct Postgres connection, for Drizzle / migrations. Settings → Database.
DATABASE_URL=

# Set to "1" to force the in-memory seed data layer even if Supabase env is present.
DRILLIN_USE_SEED_DATA=1
